#
# ~/.bash_profile
#


function set_packages()
{
    # OS detection
    local OS
    case "$(uname -s)" in
        Darwin) OS=macos ;;
        Linux)  OS=linux; [ -r /etc/os-release ] && . /etc/os-release && OS=$ID ;;
    esac

    # Common packages for every OS
    local pkgs=(git gh gnupg emacs tmux zsh)

    case "$OS" in
        macos)
            if ! command -v brew >/dev/null 2>&1; then
                echo "Homebrew가 필요합니다: https://brew.sh"
                return 1
            fi
            pkgs+=(pinentry-mac)
            for p in "${pkgs[@]}"; do
                if brew list "$p" >/dev/null 2>&1; then echo "$p 설치됨"; else brew install "$p"; fi
            done
            ;;
        ubuntu|debian)
            pkgs+=(pinentry-curses scrot xclip)
            sudo apt-get update
            for p in "${pkgs[@]}"; do
                if dpkg -s "$p" >/dev/null 2>&1; then echo "$p 설치됨"; else sudo apt-get install -y "$p"; fi
            done
            ;;
        arch)
            pkgs+=(pinentry scrot xclip)
            for p in "${pkgs[@]}"; do
                if pacman -Q "$p" >/dev/null 2>&1; then echo "$p 설치됨"; else sudo pacman -S --noconfirm "$p"; fi
            done
            ;;
        *)
            echo "지원하지 않는 OS: $OS"
            return 1
            ;;
    esac
}

# gpg-agent의 pinentry-program을 OS에 맞게 설정 (멱등).
function gpg_set_pinentry()
{
    local conf="$HOME/.gnupg/gpg-agent.conf" prog="" c
    case "$(uname -s)" in
        Darwin)
            for c in /opt/homebrew/bin/pinentry-mac /usr/local/bin/pinentry-mac; do
                [ -x "$c" ] && prog="$c" && break
            done ;;
        Linux)
            for c in /usr/bin/pinentry-curses /usr/bin/pinentry-gnome3 /usr/bin/pinentry; do
                [ -x "$c" ] && prog="$c" && break
            done ;;
    esac
    if [ -z "$prog" ]; then
        echo "pinentry를 찾지 못했습니다 — set_packages로 설치하세요."
        return 1
    fi
    mkdir -p "$HOME/.gnupg" && chmod 700 "$HOME/.gnupg"
    if [ -f "$conf" ]; then
        grep -v '^pinentry-program' "$conf" > "$conf.tmp" && mv "$conf.tmp" "$conf"
    fi
    echo "pinentry-program $prog" >> "$conf"
    gpg-connect-agent reloadagent /bye >/dev/null 2>&1
    echo "pinentry-program → $prog"
}

# OS에 맞는 git credential helper를 ~/.gitconfig.local에 설정.
function set_git()
{
    local helper
    case "$(uname -s)" in
        Darwin) helper=osxkeychain ;;
        Linux)
            if [ -x /usr/lib/git-core/git-credential-libsecret ]; then
                helper=/usr/lib/git-core/git-credential-libsecret
            else
                helper='cache --timeout=86400'
            fi ;;
    esac
    git config --file "$HOME/.gitconfig.local" credential.helper "$helper"
    echo "git credential.helper = $helper (→ ~/.gitconfig.local)"
}

# macOS: PAM에 Touch ID(지문)를 등록해 sudo 인증을 지문으로 처리 (멱등).
# /etc/pam.d/sudo_local 은 OS 업데이트에도 보존되는 Apple 권장 위치이며,
# /etc/pam.d/sudo 가 기본으로 이 파일을 include 하므로 sudo_local 만 작성하면 된다.
# tmux/screen 세션 안에서도 지문 프롬프트가 뜨도록 pam_reattach 도 함께 설정한다.
function set_touchid()
{
    if [ "$(uname -s)" != "Darwin" ]; then
        echo "set_touchid: macOS 전용입니다 (현재 $(uname -s)). 건너뜀."
        return 1
    fi

    local sudo_local="/etc/pam.d/sudo_local"
    local tid_line="auth       sufficient     pam_tid.so"
    local reattach_line=""

    # (선택) tmux/screen 안에서도 Touch ID 프롬프트가 뜨도록 pam_reattach 설치
    if command -v brew >/dev/null 2>&1; then
        brew list pam-reattach >/dev/null 2>&1 || brew install pam-reattach
        local so="$(brew --prefix)/lib/pam/pam_reattach.so"
        [ -f "$so" ] && reattach_line="auth       optional       $so"
    else
        echo "set_touchid: Homebrew 없음 → tmux용 pam_reattach 생략, sudo만 설정."
    fi

    # pam_reattach 는 반드시 pam_tid 보다 앞에 와야 한다.
    {
        echo "# managed by devenv set_touchid — Touch ID for sudo"
        [ -n "$reattach_line" ] && echo "$reattach_line"
        echo "$tid_line"
    } | sudo tee "$sudo_local" >/dev/null

    echo "set_touchid: 완료 → 새 터미널에서 'sudo -v' 실행 시 지문 인증창이 떠야 함."
    echo "  참고) SSH 클라이언트 키에 지문을 쓰려면 PAM이 아니라 Secure Enclave 키가 필요"
    echo "        (ssh-keygen -t ecdsa-sk, 또는 Secretive 앱)."
}

function install_yaypkgs()
{
    . /etc/os-release

    pacman -S --needed git base-devel
    git clone https://aur.archlinux.org/yay-bin.git $HOME/yay-bin
    cd yay-bin
    makepkg -si
    popd
    
    declare -A cmds
    cmds=([scrot]="scrot" [xclip]="xclip" [glow]="glow")
    for cmd in "${!cmds[@]}"; do
        if [[ -z "$(type -all $cmd)" || $?!="0" ]]; then
            echo Trying to install ${cmds[$cmd]}
            yay -Syu --noconfirm ${cmds[$cmd]}
        else
            echo $cmd command exist.
        fi
    done
}

