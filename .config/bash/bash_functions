function set_packages()
{
    # OS detection
    local OS
    case "$(uname -s)" in
        Darwin) OS=macos ;;
        Linux)  OS=linux; [ -r /etc/os-release ] && . /etc/os-release && OS=$ID ;;
    esac

    # Common packages for every OS
    local pkgs=(git gh gnupg emacs tmux zsh)

    case "$OS" in
        macos)
            if ! command -v brew >/dev/null 2>&1; then
                echo "Homebrewк°Җ н•„мҡ”н•©лӢҲлӢӨ: https://brew.sh"
                return 1
            fi
            pkgs+=(pinentry-mac)
            for p in "${pkgs[@]}"; do
                if brew list "$p" >/dev/null 2>&1; then echo "$p м„Өм№ҳлҗЁ"; else brew install "$p"; fi
            done
            ;;
        ubuntu|debian)
            pkgs+=(pinentry-curses scrot xclip)
            sudo apt-get update
            for p in "${pkgs[@]}"; do
                if dpkg -s "$p" >/dev/null 2>&1; then echo "$p м„Өм№ҳлҗЁ"; else sudo apt-get install -y "$p"; fi
            done
            ;;
        arch)
            pkgs+=(pinentry scrot xclip)
            for p in "${pkgs[@]}"; do
                if pacman -Q "$p" >/dev/null 2>&1; then echo "$p м„Өм№ҳлҗЁ"; else sudo pacman -S --noconfirm "$p"; fi
            done
            ;;
        *)
            echo "м§Җмӣҗн•ҳм§Җ м•ҠлҠ” OS: $OS"
            return 1
            ;;
    esac
}

# gpg-agentмқҳ pinentry-programмқ„ OSм—җ л§һкІҢ м„Өм • (л©ұл“ұ).
function gpg_set_pinentry()
{
    local conf="$HOME/.gnupg/gpg-agent.conf" prog="" c
    case "$(uname -s)" in
        Darwin)
            for c in /opt/homebrew/bin/pinentry-mac /usr/local/bin/pinentry-mac; do
                [ -x "$c" ] && prog="$c" && break
            done ;;
        Linux)
            for c in /usr/bin/pinentry-curses /usr/bin/pinentry-gnome3 /usr/bin/pinentry; do
                [ -x "$c" ] && prog="$c" && break
            done ;;
    esac
    if [ -z "$prog" ]; then
        echo "pinentryлҘј м°ҫм§Җ лӘ»н–ҲмҠөлӢҲлӢӨ вҖ” set_packagesлЎң м„Өм№ҳн•ҳм„ёмҡ”."
        return 1
    fi
    mkdir -p "$HOME/.gnupg" && chmod 700 "$HOME/.gnupg"
    if [ -f "$conf" ]; then
        grep -v '^pinentry-program' "$conf" > "$conf.tmp" && mv "$conf.tmp" "$conf"
    fi
    echo "pinentry-program $prog" >> "$conf"
    gpg-connect-agent reloadagent /bye >/dev/null 2>&1
    echo "pinentry-program вҶ’ $prog"
}

# OSм—җ л§һлҠ” git credential helperлҘј ~/.gitconfig.localм—җ м„Өм •.
function set_git()
{
    local helper
    case "$(uname -s)" in
        Darwin) helper=osxkeychain ;;
        Linux)
            if [ -x /usr/lib/git-core/git-credential-libsecret ]; then
                helper=/usr/lib/git-core/git-credential-libsecret
            else
                helper='cache --timeout=86400'
            fi ;;
    esac
    git config --file "$HOME/.gitconfig.local" credential.helper "$helper"
    echo "git credential.helper = $helper (вҶ’ ~/.gitconfig.local)"
}

function install_yaypkgs()
{
    . /etc/os-release

    pacman -S --needed git base-devel
    git clone https://aur.archlinux.org/yay-bin.git $HOME/yay-bin
    cd yay-bin
    makepkg -si
    popd
    
    declare -A cmds
    cmds=([scrot]="scrot" [xclip]="xclip" [glow]="glow")
    for cmd in "${!cmds[@]}"; do
        if [[ -z "$(type -all $cmd)" || $?!="0" ]]; then
            echo Trying to install ${cmds[$cmd]}
            yay -Syu --noconfirm ${cmds[$cmd]}
        else
            echo $cmd command exist.
        fi
    done
}

