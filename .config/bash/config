#!/bin/bash

# Editor — emacs first, then fallbacks
for ed in emacs vim vi nano; do
  if command -v "$ed" >/dev/null 2>&1; then
    export EDITOR="$ed" VISUAL="$ed" FCEDIT="$ed"
    break
  fi
done
if [ "$EDITOR" = emacs ]; then
  export EDITOR='emacs -nw' VISUAL='emacs -nw' FCEDIT='emacs -nw'
fi

shopt -s checkwinsize
