#!/bin/zsh

# ── OS detection (runtime, single source) ──────────────────────────────────
case "$(uname -s)" in
  Darwin) DOTFILES_OS=macos ;;
  Linux)  DOTFILES_OS=linux; [ -r /etc/os-release ] && . /etc/os-release && DOTFILES_OS=$ID ;;
  *)      DOTFILES_OS="$(uname -s)" ;;
esac
export DOTFILES_OS

# ── Editor — emacs first, then fallbacks ───────────────────────────────────
for ed in emacs vim vi nano; do
  if command -v "$ed" >/dev/null 2>&1; then
    export EDITOR="$ed" VISUAL="$ed"
    break
  fi
done
[ "$EDITOR" = emacs ] && export EDITOR='emacs -nw' VISUAL='emacs -nw'

# ── GPG / SSH via gpg-agent ────────────────────────────────────────────────
export GPG_TTY="${TTY:-$(tty)}"
if command -v gpgconf >/dev/null 2>&1; then
  unset SSH_AGENT_PID
  export SSH_AUTH_SOCK="$(gpgconf --list-dirs agent-ssh-socket)"
fi

# ── git prompt hints ───────────────────────────────────────────────────────
export GIT_PS1_SHOWUPSTREAM="verbose name"
export GIT_PS1_DESCRIBE_STYLE="branch"
export GIT_PS1_SHOWCOLORHINTS="true"

export LESSCHARSET=utf-8

# Doom emacs bin, if present
[ -d "$HOME/.config/emacs/bin" ] && export PATH="$PATH:$HOME/.config/emacs/bin"
